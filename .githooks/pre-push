#!/bin/bash
# pre-push: sync marketplace.json sha to the tip commit being pushed.
# Reads the remote ref from stdin to know what's being pushed.
# If marketplace.json is already up-to-date with what's being pushed, skip.

MARKETPLACE=".claude-plugin/marketplace.json"
[ -f "$MARKETPLACE" ] || exit 0

# Read the push refs from stdin (format: local_ref local_sha remote_ref remote_sha)
# We want the local_sha (what we're pushing up to).
PUSH_SHA=""
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "$local_sha" ] && PUSH_SHA="$local_sha"
done
[ -z "$PUSH_SHA" ] && exit 0

CURRENT=$(python3 -c "
import json, sys
try:
  d = json.load(open('$MARKETPLACE'))
  print(d['plugins'][0]['source']['sha'])
except Exception:
  print('')
" 2>/dev/null)

[ "$CURRENT" = "$PUSH_SHA" ] && exit 0

python3 -c "
import json
with open('$MARKETPLACE') as f:
  d = json.load(f)
d['plugins'][0]['source']['sha'] = '$PUSH_SHA'
with open('$MARKETPLACE', 'w') as f:
  json.dump(d, f, indent=2, ensure_ascii=False)
  f.write('\n')
"

git add "$MARKETPLACE"
git commit --no-verify -m "chore: sync marketplace sha to HEAD"

# The sync commit will be picked up in the NEXT push.
# This is intentional: the sync commit is a no-op from plugin perspective
# since it only changes marketplace.json (not installed files).
