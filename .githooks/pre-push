#!/bin/bash
# pre-push: sync marketplace.json sha to HEAD before pushing
# After committing the sync, amend marketplace.json to point to the sync commit SHA.
# Uses a sentinel file to prevent recursive triggering during the amend.

MARKETPLACE=".claude-plugin/marketplace.json"
SENTINEL=".git/.sha-sync-in-progress"
[ -f "$MARKETPLACE" ] || exit 0
[ -f "$SENTINEL" ] && exit 0  # already in sync loop, skip

SHA=$(git rev-parse HEAD)

CURRENT=$(python3 -c "
import json, sys
try:
  d = json.load(open('$MARKETPLACE'))
  print(d['plugins'][0]['source']['sha'])
except Exception:
  print('')
" 2>/dev/null)

[ "$CURRENT" = "$SHA" ] && exit 0

# Create sentinel to prevent re-entry
touch "$SENTINEL"
trap 'rm -f "$SENTINEL"' EXIT

# Write SHA of current HEAD into marketplace.json and commit
python3 -c "
import json
with open('$MARKETPLACE') as f:
  d = json.load(f)
d['plugins'][0]['source']['sha'] = '$SHA'
with open('$MARKETPLACE', 'w') as f:
  json.dump(d, f, indent=2, ensure_ascii=False)
  f.write('\n')
"
git add "$MARKETPLACE"
git commit --no-verify -m "chore: sync marketplace sha to HEAD"

# Update marketplace.json to point to the sync commit itself
SYNC_SHA=$(git rev-parse HEAD)
python3 -c "
import json
with open('$MARKETPLACE') as f:
  d = json.load(f)
d['plugins'][0]['source']['sha'] = '$SYNC_SHA'
with open('$MARKETPLACE', 'w') as f:
  json.dump(d, f, indent=2, ensure_ascii=False)
  f.write('\n')
"
git add "$MARKETPLACE"
git commit --no-verify --amend --no-edit
